# Base URL of the Astro Exchange bot's Express API (no trailing slash).
# Example: https://astro-exchange-bot.up.railway.app
NEXT_PUBLIC_ASTRO_API_URL=

# Discord invite link, used for "Join Discord" CTAs across the site.
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-invite

# Link to the Discord-based digital shop, used for "Visit Shop" CTAs.
NEXT_PUBLIC_SHOP_URL=https://discord.gg/your-invite

# Dashboard admin password (never commit the real value).
NEXT_PUBLIC_DASHBOARD_PASSWORD=

# Admin email displayed in dashboard sidebar/settings.
NEXT_PUBLIC_ADMIN_EMAIL=

# Secret token sent as Authorization header on admin API calls.
# Must match the token the bot validates on protected endpoints.
NEXT_PUBLIC_ADMIN_TOKEN=

# Discord OAuth2 (for "Login with Discord" button).
# Create an app at https://discord.com/developers/applications
# Set the redirect URI to https://yourdomain.com/auth/discord
NEXT_PUBLIC_DISCORD_CLIENT_ID=1491559959119532072

# ── Multi-tenant Platform ────────────────────────────────────────────

# PostgreSQL connection string (Railway Postgres or any PG provider).
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Base domain for subdomain routing (e.g. heavenmarket.com).
# Tenant shops become slug.heavenmarket.com
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000

# Secret used to SIGN tenant dashboard sessions (HMAC). Keep ≥16 chars.
PLATFORM_SECRET=

# Optional: separate secret for bot-facing platform endpoints
# (pending-orders, settle, migrate, wallet). Falls back to PLATFORM_SECRET if
# unset. Use a distinct value so a leaked bot credential can't forge sessions.
BOT_API_SECRET=

# BlockCypher API token — used to generate tenant/order LTC & BTC wallets and
# to verify on-chain payment amounts. Same token the Discord bot uses.
BLOCKCYPHER_TOKEN=

# 32-byte key (base64 or 64-hex) used to encrypt wallet private keys at rest
# with AES-256-GCM. Generate: openssl rand -base64 32
# If unset, keys are stored as plaintext (NOT recommended for production).
WALLET_ENC_KEY=

# Your personal LTC wallet — receives the platform fee (3%) on tenant sales.
PLATFORM_LTC_ADDRESS=

# Minimum confirmations required before the settle endpoint accepts a payment.
LTC_MIN_CONFIRMATIONS=1

# Vercel Blob token for logo uploads (auto-set when you connect a Blob store).
BLOB_READ_WRITE_TOKEN=
